# Application
APP_SECRET_KEY=replace-with-a-secure-random-string
ENVIRONMENT=development
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173

# PostgreSQL
POSTGRES_DB=phoenix
POSTGRES_USER=phoenix
POSTGRES_PASSWORD=phoenix123
DATABASE_URL=postgresql+asyncpg://phoenix:phoenix123@db:5432/phoenix

# Redis / RabbitMQ
REDIS_URL=redis://redis:6379/0
RABBITMQ_DEFAULT_USER=phoenix
RABBITMQ_DEFAULT_PASS=phoenix123
RABBITMQ_URL=amqp://phoenix:phoenix123@rabbitmq:5672//

# LLM Provider: openai or deepseek
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Embedding
EMBEDDING_MODEL=

# Runtime
RAG_TOP_K=5
RAG_CACHE_SECONDS=3600
SESSION_CACHE_SECONDS=600
LLM_CACHE_SECONDS=600
UVICORN_WORKERS=2
CELERY_WORKER_CONCURRENCY=2
NGINX_PORT=80
